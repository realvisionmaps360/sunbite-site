{
  "routes": [
    { "src": "/opening/assets/(.*)", "dest": "/opening/assets/$1" },
    {
      "src": "/opening/?",
      "dest": "/opening/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "CDN-Cache-Control": "no-store",
        "Vercel-CDN-Cache-Control": "no-store"
      }
    },
    { "src": "/invitation/assets/(.*)", "dest": "/invitation/assets/$1" },
    {
      "src": "/invitation/?",
      "dest": "/invitation/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "CDN-Cache-Control": "no-store",
        "Vercel-CDN-Cache-Control": "no-store"
      }
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "rewrites": [
    { "source": "/eroffnung", "destination": "https://sunbite-opening18.vercel.app/eroffnung/" },
    { "source": "/eroffnung/:match*", "destination": "https://sunbite-opening18.vercel.app/eroffnung/:match*" }
  ]
}