{
  "routes": [
    { "src": "/opening/assets/(.*)", "dest": "/opening/assets/$1" },
    {
      "src": "/opening/?",
      "dest": "/opening/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "CDN-Cache-Control": "no-store",
        "Vercel-CDN-Cache-Control": "no-store"
      }
    },
    { "src": "/invitation/assets/(.*)", "dest": "/invitation/assets/$1" },
    {
      "src": "/invitation/?",
      "dest": "/invitation/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "CDN-Cache-Control": "no-store",
        "Vercel-CDN-Cache-Control": "no-store"
      }
    },
    { "src": "/eroeffnung/assets/(.*)", "dest": "/eroeffnung/assets/$1" },
    {
      "src": "/eroeffnung/?",
      "dest": "/eroeffnung/index.html",
      "headers": {
        "Cache-Control": "no-store, no-cache, must-revalidate",
        "CDN-Cache-Control": "no-store",
        "Vercel-CDN-Cache-Control": "no-store"
      }
    },
    { "src": "/eroffnung(?:/.*)?", "status": 308, "headers": { "Location": "/eroeffnung/" } },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}