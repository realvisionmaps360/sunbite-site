{
  "headers": [
    {
      "source": "/invitation(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "routes": [
    { "src": "/invitation/assets/(.*)", "dest": "/invitation/assets/$1" },
    { "src": "/invitation", "dest": "/invitation/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
